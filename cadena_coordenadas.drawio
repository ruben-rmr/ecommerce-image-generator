<mxfile host="app.diagrams.net" type="device">
  <diagram name="Cadena de coordenadas" id="coord-chain">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Cadena de transformaciones de coordenadas (bbox / máscara)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="20" width="840" height="30" as="geometry" />
        </mxCell>

        <mxCell id="n1" value="(1) Píxeles de pantalla&#10;&#10;evento de ratón sobre el &lt;img&gt;&#10;(coords del DOM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="n2" value="(2) Coordenadas relativas [0,1]&#10;&#10;[x1,y1,x2,y2] normalizadas&#10;formato de transporte API&#10;(JSON en form-data)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="330" y="220" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="n3" value="(3) Píxeles absolutos de la imagen&#10;&#10;resolución original subida&#10;(W×H reales del producto)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="620" y="220" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="n4" value="(4) Píxeles del lienzo letterbox&#10;&#10;escalado a 1024px estilo YOLO&#10;+ padding (metadata escala/pad)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="910" y="220" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="n5" value="(5) Píxeles del tensor de máscara&#10;&#10;salida FastSAM&#10;(máscara en grid del modelo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1200" y="220" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;fontSize=11;" edge="1" parent="1" source="n1" target="n2">
          <mxGeometry relative="1" as="geometry" />
          <mxCell id="e12l" value="normalizar&#10;÷ tamaño mostrado" style="edgeLabel;html=1;align=center;fontSize=10;" vertex="1" connectable="0" parent="e12">
            <mxGeometry x="-0.1" y="-1" relative="1" as="geometry" />
          </mxCell>
        </mxCell>

        <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;fontSize=11;" edge="1" parent="1" source="n2" target="n3">
          <mxGeometry relative="1" as="geometry" />
          <mxCell id="e23l" value="× (W,H) imagen" style="edgeLabel;html=1;align=center;fontSize=10;" vertex="1" connectable="0" parent="e23">
            <mxGeometry x="-0.1" y="-1" relative="1" as="geometry" />
          </mxCell>
        </mxCell>

        <mxCell id="e34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;fontSize=11;" edge="1" parent="1" source="n3" target="n4">
          <mxGeometry relative="1" as="geometry" />
          <mxCell id="e34l" value="letterbox&#10;× escala + padding" style="edgeLabel;html=1;align=center;fontSize=10;" vertex="1" connectable="0" parent="e34">
            <mxGeometry x="-0.1" y="-1" relative="1" as="geometry" />
          </mxCell>
        </mxCell>

        <mxCell id="e45" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;fontSize=11;" edge="1" parent="1" source="n4" target="n5">
          <mxGeometry relative="1" as="geometry" />
          <mxCell id="e45l" value="inferencia FastSAM" style="edgeLabel;html=1;align=center;fontSize=10;" vertex="1" connectable="0" parent="e45">
            <mxGeometry x="-0.1" y="-1" relative="1" as="geometry" />
          </mxCell>
        </mxCell>

        <mxCell id="e53" value="retorno: revertir padding + escala&#10;(máscara → píxeles de imagen, clip al bbox)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=block;dashed=1;strokeColor=#9673a6;fontColor=#9673a6;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="n5" target="n3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1300" y="470" />
              <mxPoint x="720" y="470" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="legend" value="Flujo de ida (sólido): pantalla → API → imagen → letterbox → tensor.&#10;Flujo de retorno (discontinuo): tensor de máscara → píxeles de imagen original." style="text;html=1;strokeColor=#cccccc;fillColor=#f5f5f5;align=left;verticalAlign=middle;fontSize=11;rounded=1;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="330" y="540" width="780" height="60" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
