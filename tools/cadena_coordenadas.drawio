<mxfile host="app.diagrams.net" agent="Claude Code">
  <diagram name="Cadena de coordenadas" id="cadena-coords">
    <mxGraphModel dx="1230" dy="676" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="c1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;1. Píxeles de pantalla&lt;/b&gt;&lt;br&gt;&lt;br&gt;Posición del ratón sobre el &lt;img&gt;origen en la esquina del elemento; incluye el letterbox de object-fit: contain." vertex="1">
          <mxGeometry height="120" width="250" x="40" y="120" as="geometry" />
        </mxCell>
        <mxCell id="c2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;2. Coordenadas relativas [0,1]&lt;/b&gt;&lt;br&gt;&lt;br&gt;getImageBounds() compensa el contain&lt;br&gt;y normaliza a [x1,y1,x2,y2] ∈ [0,1].&lt;br&gt;Formato que viaja al backend (JSON&lt;br&gt;en form-data), independiente del tamaño." vertex="1">
          <mxGeometry height="120" width="250" x="330" y="120" as="geometry" />
        </mxCell>
        <mxCell id="c3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;3. Píxeles absolutos de la imagen&lt;/b&gt;&lt;br&gt;&lt;br&gt;Relativas × (ancho, alto) reales del&lt;br&gt;PIL.Image recibido. Sistema en el que&lt;br&gt;se recorta y se devuelve el RGBA final." vertex="1">
          <mxGeometry height="120" width="250" x="620" y="120" as="geometry" />
        </mxCell>
        <mxCell id="c4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;4. Píxeles del lienzo letterbox&lt;/b&gt;&lt;br&gt;&lt;br&gt;Letterbox estilo YOLO a 1024 px:&lt;br&gt;escala uniforme + padding centrado.&lt;br&gt;Se guarda metadata (ratio, dw, dh)&lt;br&gt;para poder revertir la transformación." vertex="1">
          <mxGeometry height="120" width="250" x="910" y="120" as="geometry" />
        </mxCell>
        <mxCell id="c5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;5. Píxeles del tensor de máscara&lt;/b&gt;&lt;br&gt;&lt;br&gt;Espacio de salida de FastSAM&lt;br&gt;(resolución del lienzo letterbox).&lt;br&gt;La máscara seleccionada nace aquí." vertex="1">
          <mxGeometry height="120" width="250" x="1200" y="120" as="geometry" />
        </mxCell>
        <mxCell id="e12" edge="1" parent="1" source="c1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;" target="c2" value="compensar contain&#xa;+ normalizar">
          <mxGeometry relative="1" y="-80" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e23" edge="1" parent="1" source="c2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;" target="c3" value="× tamaño real&#xa;de la imagen">
          <mxGeometry relative="1" y="-80" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e34" edge="1" parent="1" source="c3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;" target="c4" value="escala + padding&#xa;(letterbox 1024)">
          <mxGeometry relative="1" y="-80" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e45" edge="1" parent="1" source="c4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;" target="c5" value="inferencia&#xa;FastSAM">
          <mxGeometry relative="1" y="-80" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e53" edge="1" parent="1" source="c5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#b85450;fontColor=#b85450;dashed=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;" target="c3" value="&lt;b&gt;revertir padding + escala&lt;br&gt;(metadata del letterbox)&lt;br&gt;→ recorte y clip al bbox&lt;/b&gt;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1325" y="60" />
              <mxPoint x="745" y="60" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="titulo" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;" value="Cadena de transformaciones de coordenadas (frontend → backend → máscara → recorte)" vertex="1">
          <mxGeometry height="30" width="1410" x="40" y="300" as="geometry" />
        </mxCell>
        <mxCell id="4sYjW_Ocwg-wJ8dYcEUh-1" edge="1" parent="1" style="endArrow=none;dashed=1;html=1;dashPattern=1 3;strokeWidth=2;rounded=0;" value="">
