        <!-- FALLBACK: v1 -> s2 -->
        <mxCell id="f1" value="No (fallback)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#b85450;fontColor=#b85450;" edge="1" parent="1" source="v1" target="s2">
          <mxGeometry relative="1" as="geometry" />
