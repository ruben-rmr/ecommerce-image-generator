        <mxCell id="ok3" value="Sí" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#82b366;fontColor=#3a7d34;" edge="1" parent="1" source="v3" target="ok">
          <mxGeometry relative="1" as="geometry" />
