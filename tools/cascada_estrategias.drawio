        <!-- v2 -> s3 -->
        <mxCell id="f2" value="No (fallback)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#b85450;fontColor=#b85450;" edge="1" parent="1" source="v2" target="s3">
          <mxGeometry relative="1" as="geometry" />
