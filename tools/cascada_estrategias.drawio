        <!-- v3 -> s4 -->
        <mxCell id="f3" value="No (fallback)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#b85450;fontColor=#b85450;" edge="1" parent="1" source="v3" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
