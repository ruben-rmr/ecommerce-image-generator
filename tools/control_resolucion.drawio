        <mxCell id="subtitulo" parent="1" style="text;html=1;fontSize=12;fontColor=#666666;align=center;" value="Dos cotas independientes gobiernan la cadena de tamaños: la resolución de trabajo (max_side) y el lienzo cuadrado de inferencia (1024)." vertex="1">
