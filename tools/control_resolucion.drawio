        <mxCell id="cota1_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#82b366;strokeWidth=2;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#5a8a3a;spacingTop=4;" value="Cota 1 — resolución de trabajo" vertex="1">
          <mxGeometry height="290" width="200" x="320" y="155" as="geometry" />
        </mxCell>
        <mxCell id="cota1_lbl" parent="1" style="text;html=1;fontSize=11;fontColor=#5a8a3a;align=center;" value="&lt;b&gt;max_side (parámetro de form-data,&amp;nbsp;&lt;/b&gt;&lt;div&gt;&lt;b&gt;opcional) limita el coste de inferencia&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;y fija la resolución del recorte final&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="200" x="320" y="385" as="geometry" />
        </mxCell>
        <mxCell id="cota2_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#d6b656;strokeWidth=2;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#a8862a;spacingTop=4;" value="Cota 2 — lienzo de inferencia" vertex="1">
          <mxGeometry height="290" width="440" x="580" y="155" as="geometry" />
        </mxCell>
        <mxCell id="cota2_lbl" parent="1" style="text;html=1;fontSize=11;fontColor=#a8862a;align=center;" value="&lt;b&gt;target_size = 1024 (fijo, estilo YOLO)&lt;br&gt;tamaño que exige el modelo; independiente&lt;br&gt;de la resolución de trabajo&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="440" x="580" y="385" as="geometry" />
        </mxCell>
        <mxCell id="nota" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;align=left;spacingLeft=12;verticalAlign=top;spacingTop=10;" value="Idea central: las dos cotas son independientes.&#xa;• max_side puede subir/bajar la calidad del recorte sin tocar el modelo.&#xa;• El lienzo 1024 siempre normaliza la entrada de FastSAM (scale ≤ 1).&#xa;• La máscara se calcula a 1024, pero el resultado vuelve siempre a W×H (no al original).&#xa;Origen: _resize_for_segmentation() en main.py · preprocess_image()/postprocess_mask() en segmentation.py." vertex="1">
          <mxGeometry height="120" width="700" x="70" y="560" as="geometry" />
        </mxCell>
