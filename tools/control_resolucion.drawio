          <mxGeometry height="90" width="180" x="330" y="180" as="geometry" />
        </mxCell>
        <mxCell id="N3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;" value="&lt;b&gt;Lienzo de inferencia&lt;/b&gt;&lt;br&gt;1024 × 1024&lt;br&gt;&lt;span style=&quot;color:#666;&quot;&gt;letterbox cuadrado + padding gris (114)&lt;/span&gt;" vertex="1">
          <mxGeometry height="90" width="180" x="590" y="180" as="geometry" />
