          <mxGeometry height="90" width="180" x="1050" y="350" as="geometry" />
        </mxCell>
        <mxCell id="e12" edge="1" parent="1" source="N1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#333333;fontSize=11;align=center;verticalAlign=bottom;" target="N2" value="resize LANCZOS&#xa;(si supera max_side)">
