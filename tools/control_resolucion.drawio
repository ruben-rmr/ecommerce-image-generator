        <mxCell id="e45" edge="1" parent="1" source="N4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#333333;fontSize=11;align=center;verticalAlign=middle;" target="N5" value="postprocess_mask()&#xa;quita padding + INTER_NEAREST a W×H">
          <mxGeometry relative="1" x="-0.0638" y="39" as="geometry">
