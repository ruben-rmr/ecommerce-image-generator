        <mxCell id="N4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;" value="&lt;b&gt;Máscara&lt;/b&gt;&lt;br&gt;1024 × 1024&lt;br&gt;&lt;span style=&quot;color:#666;&quot;&gt;salida de FastSAM&lt;/span&gt;" vertex="1">
          <mxGeometry height="90" width="180" x="850" y="180" as="geometry" />
